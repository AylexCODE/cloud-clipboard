{
	"name": "cloud-clipboard",
	"displayName": "Cloud Clipboard",
	"description": "Copy and paste text anywhere",
	"version": "0.0.1",
	"publisher": "AylexCODE",
	"repository": "https://github.com/AylexCODE/cloud-clipboard",
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "Cloud Clipboard",
			"properties": {
				"cloudclipboard.configuration": {
					"type": "string",
					"default": "",
					"description": "Clipboard API Endpoint"
				}
			}
		},
		"commands": [
			{
				"command": "cloudclipboard.paste",
				"title": "Cloud Clipboard Paste"
			},
			{
				"command": "cloudclipboard.copy",
				"title": "Cloud Clipboard Copy"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"command": "cloudclipboard.paste",
					"group": "navigation"
				},
				{
					"command": "cloudclipboard.copy",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"compile": "tsc -p ./"
	},
	"devDependencies": {
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"typescript": "^5.8.2"
	}
}