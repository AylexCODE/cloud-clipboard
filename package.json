{
	"name": "cloud-clipboard",
	"displayName": "Cloud Clipboard",
	"description": "Copy and paste text, files, or folders across any VS Code instance.",
	"version": "0.1.6",
	"publisher": "AylexCODE",
	"license": "MIT",
	"icon": "img/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/AylexCODE/cloud-clipboard"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"extensionKind": [
		"workspace"
	],
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"title": "Cloud Clipboard",
			"properties": {
				"cloudclipboard.namespace": {
					"type": "string",
					"default": "",
					"description": "Clipboard Namespace."
				},
				"cloudclipboard.sortResults": {
					"type": "string",
					"enum": ["ascending", "descending", "date_ascending", "date_descending"],
					"default": "ascending",
					"description": "Sort Clipboard Namespace Results."
				},
				"cloudclipboard.forcePaste": {
					"type": "boolean",
					"default": false,
					"description": "Always Replace Existing Items."
				},
				"cloudclipboard.endpoint": {
					"type": "string",
					"default": "https://cloud-clipboard-api.onrender.com",
					"description": "Clipboard API Endpoint."
				}
			}
		},
		"commands": [
			{
				"command": "cloudclipboard.copy",
				"title": "Copy"
			},
			{
				"command": "cloudclipboard.paste",
				"title": "Paste"
			},
			{
				"command": "cloudclipboard.delete",
				"title": "Delete"
			},
			{
				"command": "cloudclipboard.editorCopy",
				"title": "Copy"
			},
			{
				"command": "cloudclipboard.editorPaste",
				"title": "Paste"
			}
		],
		"submenus": [
			{
				"id": "cloudClipboard",
				"label": "Cloud Clipboard"
			},
			{
				"id": "cloudClipboardEditor",
				"label": "Cloud Clipboard"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "cloudclipboard.copy",
					"when": "false"
				},
				{
					"command": "cloudclipboard.paste",
					"when": "false"
				},
				{
					"command": "cloudclipboard.delete",
					"when": "false"
				},
				{
					"command": "cloudclipboard.editorCopy",
					"when": "false"
				},
				{
					"command": "cloudclipboard.editorPaste",
					"when": "false"
				}
			],
			"explorer/context": [
				{
					"submenu": "cloudClipboard",
					"group": "cloud_clipboard",
					"when": "explorerResourceIsFolder || !explorerResourceIsFolder"
				}
			],
			"cloudClipboard": [
				{
					"command": "cloudclipboard.copy",
					"group": "cloud_clipboard"
				},
				{
					"command": "cloudclipboard.paste",
					"group": "cloud_clipboard"
				},
				{
					"command": "cloudclipboard.delete",
					"group": "cloud_clipboard"
				}
			],
			"editor/context": [
				{
					"submenu": "cloudClipboardEditor",
					"group": "cloud_clipboard",
					"when": "editorTextFocus"
				}
			],
			"cloudClipboardEditor": [
				{
					"command": "cloudclipboard.editorCopy",
					"group": "cloud_clipboard"
				},
				{
					"command": "cloudclipboard.editorPaste",
					"group": "cloud_clipboard"
				},
				{
					"command": "cloudclipboard.delete",
					"group": "cloud_clipboard"
				}
			]
		}
	},
	"scripts": {
		"compile": "tsc -p ./"
	},
	"devDependencies": {
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"typescript": "^5.8.2"
	}
}